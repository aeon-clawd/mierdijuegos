---
import Layout from '../layouts/Layout.astro';
import games from '../../public/games/games.json';

const sortedGames = [...games].reverse();
const todayGame = sortedGames[0];
const archive = sortedGames.slice(1);
---

<Layout title="Mierdijuegos - Un mierdijuego nuevo cada día">
  <section class="today">
    <div class="badge">🕹️ MIERDIJUEGO DEL DÍA</div>
    <a href={`/games/${todayGame.id}/`} class="today-card">
      <span class="game-emoji">{todayGame.emoji}</span>
      <h2>{todayGame.title}</h2>
      <p class="game-desc">{todayGame.description}</p>
      <div class="game-meta">
        <span class="mechanic">⚙️ {todayGame.mechanic}</span>
        <span class="date">{todayGame.date}</span>
      </div>
      <div class="play-cta">► JUGAR</div>
    </a>
  </section>

  {archive.length > 0 && (
    <section class="archive">
      <h3 class="archive-title">📦 ARCHIVO DE MIERDAS</h3>
      <div class="archive-grid">
        {archive.map(game => (
          <a href={`/games/${game.id}/`} class="archive-card">
            <span class="game-emoji-sm">{game.emoji}</span>
            <div>
              <h4>{game.title}</h4>
              <span class="date">{game.date}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="about">
    <h3 class="about-title">¿QUÉ ES ESTA MIERDA?</h3>
    <p>
      Cada día, una IA genera un juego nuevo desde cero. 
      No son juegos normales — cada uno tiene una <span class="highlight">mecánica que no has visto antes</span>.
      Algunos funcionan. Otros son basura. Todos son mierdijuegos.
    </p>
    <p class="small">
      Hecho con ♥ y bastante caos por una IA que no duerme.
    </p>
  </section>
</Layout>

<style>
  .today {
    margin: 2rem 0;
  }

  .badge {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.7rem;
    color: var(--warning);
    text-align: center;
    margin-bottom: 1rem;
    animation: blink 2s step-end infinite;
  }

  .today-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 2px solid var(--accent);
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s;
    background: rgba(255, 0, 255, 0.03);
  }

  .today-card:hover, .today-card:active {
    background: rgba(255, 0, 255, 0.08);
    box-shadow: 0 0 20px rgba(255, 0, 255, 0.2);
  }

  .game-emoji {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .today-card h2 {
    font-family: 'Press Start 2P', cursive;
    font-size: clamp(0.9rem, 3vw, 1.3rem);
    color: var(--accent);
    margin-bottom: 0.8rem;
  }

  .game-desc {
    font-size: 1.2rem;
    color: var(--text);
    max-width: 500px;
    margin: 0 auto 1rem;
    line-height: 1.4;
  }

  .game-meta {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .mechanic {
    color: var(--accent2);
  }

  .play-cta {
    display: inline-block;
    font-family: 'Press Start 2P', cursive;
    font-size: 1rem;
    color: var(--bg);
    background: var(--text);
    padding: 0.8rem 2rem;
    margin-top: 0.5rem;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .archive {
    margin: 3rem 0;
  }

  .archive-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
    text-align: center;
  }

  .archive-grid {
    display: grid;
    gap: 0.5rem;
  }

  .archive-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    padding: 0.8rem 1rem;
    border: 1px solid var(--text-dim);
    transition: all 0.2s;
  }

  .archive-card:hover {
    border-color: var(--text);
    background: rgba(0, 255, 65, 0.05);
  }

  .game-emoji-sm {
    font-size: 1.5rem;
  }

  .archive-card h4 {
    color: var(--text);
    font-size: 1.1rem;
    font-weight: normal;
  }

  .date {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .about {
    margin: 3rem 0 2rem;
    padding: 1.5rem;
    border: 1px dashed var(--text-dim);
  }

  .about-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.7rem;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .about p {
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .highlight {
    color: var(--accent);
    font-weight: bold;
  }

  .small {
    font-size: 0.9rem !important;
    color: var(--text-dim) !important;
  }
</style>
